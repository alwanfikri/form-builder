# Database
DATABASE_URL=postgresql://formbuilder:password@localhost:5432/formbuilder
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
EXT_SESSION_SECRET=change-me-external-session-secret

# Google OAuth + APIs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
